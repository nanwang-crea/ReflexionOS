{
  "name": "reflexion-os-frontend",
  "version": "0.1.0",
  "description": "ReflexionOS Desktop Application",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-electron.mjs",
    "dev:web": "vite",
    "dev:desktop": "electron ./electron/main.cjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "electron ./electron/main.cjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^31.7.7",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
